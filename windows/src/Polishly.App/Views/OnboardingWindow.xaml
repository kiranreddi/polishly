<Window x:Class="Polishly.App.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Welcome to Polishly"
        Width="580" Height="420"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding StepTitle}" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock Text="{Binding StepDescription}" Foreground="#AAAAAA" FontSize="13" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Step Specific Visual Content -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid>
                <!-- Step 1 Content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="✨ Polishly Companion for Windows" Foreground="#4EC9B0" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Enhance emails, documents, and messages anywhere with one hotkey." Foreground="#CCCCCC" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Step Navigation Bar -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Height="Auto"/>
                <ColumnDefinition Height="*"/>
                <ColumnDefinition Height="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Back" Command="{Binding PreviousStepCommand}" Padding="16,6" Background="#3E3E42" Foreground="White" BorderThickness="0" CornerRadius="4"/>
            <TextBlock Grid.Column="1" Text="{Binding CurrentStep, StringFormat='Step {0} of 6'}" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <Button Grid.Column="2" Content="{Binding NextButtonText}" Command="{Binding NextStepCommand}" Padding="20,6" Background="#0E639C" Foreground="White" BorderThickness="0" CornerRadius="4"/>
        </Grid>
    </Grid>
</Window>
