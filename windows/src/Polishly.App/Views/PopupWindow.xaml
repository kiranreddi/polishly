<Window x:Class="Polishly.App.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Polishly Diff"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="320" MaxWidth="520">
    <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#333333" BorderThickness="1" Padding="12" Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        <StackPanel>
            <!-- Header Bar with State and Dismiss -->
            <Grid Margin="0,0,0,8">
                <TextBlock Text="{Binding StateDescription}" Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="✕" Command="{Binding DismissCommand}" HorizontalAlignment="Right" Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand" Width="20" Height="20"/>
            </Grid>

            <!-- Diff Display Area -->
            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DiffSegments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" FontSize="13" Margin="1,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Addition">
                                                <Setter Property="Foreground" Value="#4EC9B0"/>
                                                <Setter Property="Background" Value="#104EC9B0"/>
                                                <Setter Property="FontWeight" Value="Medium"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Deletion">
                                                <Setter Property="Foreground" Value="#F14C4C"/>
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Error Notification -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#F14C4C" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"
                       Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>

            <!-- Action Toolbar -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Accept" Command="{Binding AcceptCommand}" Margin="4,0" Padding="12,4" Background="#0E639C" Foreground="White" BorderThickness="0" CornerRadius="4"/>
                <Button Content="Copy" Command="{Binding CopyCommand}" Margin="4,0" Padding="12,4" Background="#3A3D41" Foreground="White" BorderThickness="0" CornerRadius="4"/>
                <Button Content="Retry" Command="{Binding RetryCommand}" Margin="4,0" Padding="12,4" Background="#3A3D41" Foreground="White" BorderThickness="0" CornerRadius="4"/>
                <Button Content="Revise..." Command="{Binding OpenReviseCommand}" Margin="4,0" Padding="12,4" Background="#3A3D41" Foreground="White" BorderThickness="0" CornerRadius="4"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
